+  }
+
+  const contextLargeMatch = text.match(/^🗜️ Context too large \(~([\d,]+) tokens\) — compressing \((\d+)\/(\d+)\)\.\.\.$/)
+
+  if (contextLargeMatch) {
+    return `🗜️ 上下文过大（约 ${contextLargeMatch[1]} 令牌），正在压缩（${contextLargeMatch[2]}/${contextLargeMatch[3]}）`
+  }
+
+  const compressedMatch = text.match(/^🗜️ Compressed (\d+) → (\d+) messages, retrying\.\.\.$/)
+
+  if (compressedMatch) {
+    return `🗜️ 已压缩消息：${compressedMatch[1]} → ${compressedMatch[2]}，正在重试…`
+  }
+
+  const reducedMatch = text.match(/^🗜️ Context reduced to ([\d,]+) tokens \(was ([\d,]+)\), retrying\.\.\.$/)
+
+  if (reducedMatch) {
