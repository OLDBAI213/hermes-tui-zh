+    if proc.returncode != 0:
+        return {
+            "success": False,
+            "subdomains": [],
+            "raw_stderr": proc.stderr,
+            "elapsed_ms": elapsed_ms,
+            "cmd": cmd,
+            "err": f"subfinder 退出码非零：{proc.returncode}",
