+  }
+
+  const switchedMatch = text.match(/^↻ Switched to fallback: (.+?) \((.+)\)$/)
+
+  if (switchedMatch) {
+    return `↻ 已切换备用模型：${switchedMatch[1]}（${switchedMatch[2]}）`
+  }
+
+  const invalidRetryMatch = text.match(/^⚠️ Max retries \((\d+)\) for invalid responses — trying fallback\.\.\.$/)
+
+  if (invalidRetryMatch) {
+    return `⚠️ 无效响应已重试 ${invalidRetryMatch[1]} 次，正在切换备用模型…`
+  }
+
+  const invalidGiveupMatch = text.match(/^❌ Max retries \((\d+)\) exceeded for invalid responses\. Giving up\.$/)
+
+  if (invalidGiveupMatch) {
+    return `❌ 无效响应重试 ${invalidGiveupMatch[1]} 次仍失败，已停止。`
+  }
+
+  const maxRetryMatch = text.match(/^⚠️ Max retries \((\d+)\) exhausted — trying fallback\.\.\.$/)
+
+  if (maxRetryMatch) {
