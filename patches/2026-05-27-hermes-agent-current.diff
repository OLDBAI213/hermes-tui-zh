+def _capture_personal_signal_candidates(user_message: str) -> list[dict[str, str]]:
+    """Append detected Xiaobai memory candidates to the local candidate inbox."""
+    signals = _classify_personal_signal_candidates(user_message)
+    if not signals:
+        return []
+
+    inbox_path = get_hermes_home() / "memory-personal" / "candidates" / "inbox.jsonl"
+    if not inbox_path.exists():
+        return []
+
+    content = user_message.strip()
+    if len(content) > _PERSONAL_SIGNAL_MAX_MESSAGE_CHARS:
+        content = content[:_PERSONAL_SIGNAL_MAX_MESSAGE_CHARS].rstrip() + "..."
+
+    existing_keys: set[tuple[str, str, str]] = set()
+    try:
+        for line in inbox_path.read_text(encoding="utf-8").splitlines():
+            if not line.strip():
+                continue
+            try:
+                obj = json.loads(line)
+            except Exception:
+                continue
+            existing_keys.add(
+                (
+                    str(obj.get("type") or ""),
+                    str(obj.get("scope") or ""),
+                    str(obj.get("content") or ""),
+                )
+            )
+    except Exception as exc:
+        logger.warning("Could not read personal signal candidate inbox %s: %s", inbox_path, exc)
+        return []
+
+    now = datetime.now().astimezone().isoformat(timespec="seconds")
+    written: list[dict[str, str]] = []
+    rows: list[str] = []
+    for signal in signals:
+        key = (signal["type"], signal["scope"], content)
+        if key in existing_keys:
+            continue
+        digest = uuid.uuid5(uuid.NAMESPACE_URL, "|".join(key)).hex[:10]
+        row = {
+            "id": f"sig-{datetime.now().strftime('%Y%m%d')}-{digest}",
+            "time": now,
+            "type": signal["type"],
+            "scope": signal["scope"],
+            "content": content,
+            "source": "explicit/offline signal detector",
+            "confidence": signal["confidence"],
+            "status": "candidate",
+            "expected_use": signal["expected_use"],
+            "memory_layer": signal["memory_layer"],
+        }
+        rows.append(json.dumps(row, ensure_ascii=False, separators=(",", ":")))
+        written.append(row)
+        existing_keys.add(key)
+
+    if not rows:
+        return []
+
+    try:
+        with inbox_path.open("a", encoding="utf-8", newline="\n") as handle:
+            for row in rows:
+                handle.write(row)
+                handle.write("\n")
+    except Exception as exc:
+        logger.warning("Could not append personal signal candidates to %s: %s", inbox_path, exc)
+        return []
+
+    return written
+
