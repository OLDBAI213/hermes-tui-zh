+def _load_personal_wake_context() -> str:
+    """Load the compact Xiaobai personal wake file from HERMES_HOME.
+
+    This is injected into the current user message, not the system prompt, so
+    prompt caching remains stable and session history is not mutated.
+    """
+    wake_path = get_hermes_home() / "memory-personal" / "generated" / "wake.md"
+    if not wake_path.exists():
+        return ""
+    try:
+        raw = wake_path.read_text(encoding="utf-8").strip()
+    except Exception as exc:
+        logger.warning("Could not read personal wake file %s: %s", wake_path, exc)
+        return ""
+    if not raw:
+        return ""
+    if _PERSONAL_WAKE_FORBIDDEN_RE.search(raw):
+        logger.warning("Personal wake file contains forbidden framing; skipped: %s", wake_path)
+        return ""
+    lines = raw.splitlines()
+    if len(lines) > _PERSONAL_WAKE_MAX_LINES:
+        logger.warning(
+            "Personal wake file has %s lines; truncating to %s",
+            len(lines),
+            _PERSONAL_WAKE_MAX_LINES,
+        )
+        raw = "\n".join(lines[:_PERSONAL_WAKE_MAX_LINES])
+    if len(raw) > _PERSONAL_WAKE_MAX_CHARS:
+        logger.warning(
+            "Personal wake file has %s chars; truncating to %s",
+            len(raw),
+            _PERSONAL_WAKE_MAX_CHARS,
+        )
+        raw = raw[:_PERSONAL_WAKE_MAX_CHARS].rstrip()
+    return raw
+
