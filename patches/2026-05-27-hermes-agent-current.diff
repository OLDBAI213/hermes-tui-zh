+def _select_personal_scene_cards(user_message: str, *, max_cards: int = 2) -> list[str]:
+    """Select compact Xiaobai scene cards from the current user message."""
+    if not isinstance(user_message, str) or not user_message.strip():
+        return []
+
+    text = user_message.lower()
+    scored: list[tuple[int, int, str]] = []
+    for priority, (card_name, keywords) in enumerate(_PERSONAL_SCENE_CARD_RULES):
+        score = 0
+        for keyword in keywords:
+            if keyword.lower() in text:
+                score += 1
+        if score > 0:
+            scored.append((-score, priority, card_name))
+
+    scored.sort()
+    return [card_name for _, _, card_name in scored[:max_cards]]
+
+
+def _load_personal_scene_card_context(card_names: list[str]) -> str:
+    """Load selected generated Xiaobai scene cards from HERMES_HOME."""
+    if not card_names:
+        return ""
+
+    cards_dir = get_hermes_home() / "memory-personal" / "generated" / "cards"
+    parts: list[str] = []
+    total_chars = 0
+    seen: set[str] = set()
+
+    for card_name in card_names:
+        if not re.fullmatch(r"[a-z0-9-]+", card_name):
+            continue
+        if card_name in seen:
+            continue
+        seen.add(card_name)
+
+        card_path = cards_dir / f"{card_name}.md"
+        if not card_path.exists():
+            continue
+        try:
+            raw = card_path.read_text(encoding="utf-8").strip()
+        except Exception as exc:
+            logger.warning("Could not read personal scene card %s: %s", card_path, exc)
+            continue
+        if not raw:
+            continue
+        if _PERSONAL_WAKE_FORBIDDEN_RE.search(raw):
+            logger.warning("Personal scene card contains forbidden framing; skipped: %s", card_path)
+            continue
+        next_total = total_chars + len(raw)
+        if next_total > _PERSONAL_SCENE_CARD_MAX_CHARS:
+            break
+        parts.append(f"## Selected scene card: {card_name}\n\n{raw}")
+        total_chars = next_total
+
+    return "\n\n".join(parts).strip()
+
+
+def _load_personal_working_memory_context(user_message: str) -> str:
+    """Load wake index plus scene cards selected for this turn."""
+    wake = _load_personal_wake_context()
+    cards = _load_personal_scene_card_context(_select_personal_scene_cards(user_message))
+    if wake and cards:
+        return f"{wake}\n\n# 当前场景卡\n\n{cards}"
+    return wake or cards
+
+
+def _build_personal_wake_context_block(raw_context: str) -> str:
+    """Fence personal wake context so it cannot be mistaken for user input."""
+    if not raw_context or not raw_context.strip():
+        return ""
+    clean = sanitize_context(raw_context)
+    return (
+        "<memory-context>\n"
+        "[System note: The following is Xiaobai personal working memory, "
+        "NOT new user input. Apply only when relevant to the current task; "
+        "do not quote or mention this block unless the user asks.]\n\n"
+        f"{clean}\n"
+        "</memory-context>"
+    )
+
+
+def _build_current_turn_context_injections(
+    personal_working_memory_context: str,
+    external_prefetch_context: str,
+    plugin_user_context: str,
+) -> list[str]:
+    """Build ephemeral context blocks for the current user message."""
+    injections: list[str] = []
+    if personal_working_memory_context:
+        fenced = _build_personal_wake_context_block(personal_working_memory_context)
+        if fenced:
+            injections.append(fenced)
+    if external_prefetch_context:
+        fenced = build_memory_context_block(external_prefetch_context)
+        if fenced:
+            injections.append(fenced)
+    if plugin_user_context:
+        injections.append(plugin_user_context)
+    return injections
+
 
