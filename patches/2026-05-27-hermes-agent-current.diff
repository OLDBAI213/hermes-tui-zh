+def _classify_personal_signal_candidates(user_message: str) -> list[dict[str, str]]:
+    """Detect high-confidence Xiaobai memory candidates from a user turn.
+
+    This is intentionally conservative. It only creates candidate records;
+    promotion into active memory still goes through the existing ledger flow.
+    """
+    if not isinstance(user_message, str):
+        return []
+    text = user_message.strip()
+    if len(text) < 4:
+        return []
+    lower = text.lower()
+
+    candidates: list[dict[str, str]] = []
+
+    def add_signal(
+        signal_type: str,
+        scope: str,
+        confidence: str,
+        expected_use: str,
+        memory_layer: str,
+    ) -> None:
+        if any(c["type"] == signal_type and c["scope"] == scope for c in candidates):
+            return
+        candidates.append(
+            {
+                "type": signal_type,
+                "scope": scope,
+                "confidence": confidence,
+                "expected_use": expected_use,
+                "memory_layer": memory_layer,
+            }
+        )
+
+    explicit_correction_terms = (
+        "以后别",
+        "以后不要",
+        "别这样",
+        "不要再",
+        "不能再",
+        "你这不对",
+        "还是没明白",
+        "没明白",
+        "不明白",
+        "做的有点不对",
+        "做得有点不对",
+        "记住",
+        "每次都",
+        "每次，",
+        "默认要",
+        "默认先",
+    )
+    if any(term in text for term in explicit_correction_terms):
+        add_signal(
+            "correction",
+            "xiaobai-memory",
+            "explicit",
+            "Review for promotion into correction ledger or scene coverage.",
+            "agent-operational-memory",
+        )
+
+    user_preference_terms = (
+        "我希望",
+        "我想要",
+        "我需要",
+        "我不喜欢",
+        "我喜欢",
+        "适合我",
+        "符合我",
+    )
+    if any(term in text for term in user_preference_terms):
+        add_signal(
+            "user_preference",
+            "oldbai-fit",
+            "explicit",
+            "Review as an Oldbai preference; keep concise unless repeated or severe.",
+            "agent-operational-memory",
+        )
+
+    failure_terms = (
+        "检查失败",
+        "不通过",
+        "报错",
+        "失败",
+        "你是不是做得不对",
+        "你是不是做的不对",
+        "你是不是做的有点不对",
+        "你是不是做得有点不对",
+        "做得不对",
+        "做的不对",
+        "有些问题",
+        "有问题",
+        "不对劲",
+    )
+    if any(term in text for term in failure_terms) or "error" in lower or "fail" in lower:
+        add_signal(
+            "failure_signal",
+            "xiaobai-memory",
+            "candidate",
+            "Review as a failure sample only after symptom and cause are confirmed.",
+            "agent-operational-memory",
+        )
+
+    decision_terms = (
+        "决策",
+        "怎么选",
+        "选择",
+        "结果验证",
+        "假设",
+        "推断",
+        "复盘",
+        "教训",
+        "值不值得",
+    )
+    if any(term in text for term in decision_terms):
+        add_signal(
+            "decision_memory",
+            "decision-support",
+            "candidate",
+            "Review for facts, assumptions, inference, outcome, and future replay.",
+            "agent-operational-memory",
+        )
+
+    research_rule_terms = (
+        "工具购物清单",
+        "外部项目",
+        "github上",
+        "github 上",
+        "论文",
+        "研究学习",
+        "多看多学",
+    )
+    if any(term in text for term in research_rule_terms):
+        add_signal(
+            "research_signal",
+            "xiaobai-memory",
+            "candidate",
+            "Review for research rules, borrowed mechanisms, and rejected routes.",
+            "agent-operational-memory",
+        )
+
+    if _PERSONAL_PROJECT_FACT_RE.search(text):
+        add_signal(
+            "project_fact",
+            "hermes-project",
+            "candidate",
+            "Review as project fact with source, updated date, and verification entry.",
+            "project-fact-memory",
+        )
+
+    return candidates
+
