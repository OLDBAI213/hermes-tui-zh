+const normalizeLiveStatusText = (text: string) => {
+  if (text === '↻ Stream interrupted — using delivered content as final response') {
+    return '↻ 流式响应中断，已使用已显示内容作为最终回复'
+  }
+
+  if (text === '↻ Empty response after tool calls — using earlier content as final answer') {
+    return '↻ 工具调用后模型返回空，已使用前面内容作为最终回复'
+  }
+
+  if (text === '⚠️ Model returned empty after tool calls — nudging to continue') {
+    return '⚠️ 工具调用后模型返回空，正在提示模型继续'
+  }
+
+  if (text === '⚠️ Model returning empty responses — switching to fallback provider...') {
+    return '⚠️ 模型连续返回空响应，正在切换备用模型…'
+  }
+
+  if (text === '⚠️ Empty/malformed response — switching to fallback...') {
+    return '⚠️ 模型响应为空或格式异常，正在切换备用模型…'
+  }
+
+  if (text === '⚠️ Rate limited — switching to fallback provider...') {
+    return '⚠️ 模型请求受限，正在切换备用模型…'
+  }
+
+  if (
+    text ===
+    '🔌 Detected stale connections from a previous provider issue — cleaned up automatically. Proceeding with fresh connection.'
+  ) {
+    return '🔌 检测到上次模型连接残留，已自动清理并使用新连接继续。'
+  }
+
+  if (text === '⚠️ Model produced reasoning but no visible response after all retries. Returning empty.') {
+    return '⚠️ 模型多次只返回思考，没有生成可见回复，已返回空结果。'
+  }
+
+  if (text === '🗜️ Compacting context — summarizing earlier conversation so I can continue...') {
+    return '🗜️ 正在压缩上下文，总结较早对话后继续。'
+  }
+
+  const budgetMatch = text.match(/^⚠️ Iteration budget exhausted \((\d+)\/(\d+)\) — asking model to summarise$/)
+
+  if (budgetMatch) {
+    return `⚠️ 已用完本轮迭代预算（${budgetMatch[1]}/${budgetMatch[2]}），正在请模型总结`
+  }
+
+  const preflightMatch = text.match(
+    /^📦 Preflight compression: ~([\d,]+) tokens >= ([\d,]+) threshold\. This may take a moment\.$/
+  )
+
+  if (preflightMatch) {
+    return `📦 上下文预压缩：约 ${preflightMatch[1]} 令牌，已超过 ${preflightMatch[2]} 阈值，可能需要一点时间。`
+  }
+
+  const retryMatch = text.match(/^⚠️ Empty response from model — retrying \((\d+)\/(\d+)\)$/)
+
+  if (retryMatch) {
+    return `⚠️ 模型返回空响应，正在重试（${retryMatch[1]}/${retryMatch[2]}）`
+  }
+
+  const thinkingOnlyMatch = text.match(/^↻ Thinking-only response — prefilling to continue \((\d+)\/(\d+)\)$/)
+
+  if (thinkingOnlyMatch) {
